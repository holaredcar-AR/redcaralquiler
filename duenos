<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Due&ntilde;os — RedCar</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --violeta: #542474;
    --violeta-claro: #8040b0;
    --violeta-suave: #f0e6f6;
    --negro: #111111;
    --gris: #666;
    --gris-claro: #f5f5f5;
    --borde: #e0e0e0;
    --blanco: #fff;
    --verde: #25D366;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Inter', sans-serif;
    background: var(--gris-claro);
    color: var(--negro);
    min-height: 100vh;
    padding: 28px 16px 42px;
  }
  body::before {
    content: "";
    position: fixed;
    width: 520px;
    height: 520px;
    right: -160px;
    top: -180px;
    background: radial-gradient(circle, rgba(84,36,116,0.18), transparent 70%);
    pointer-events: none;
  }
  .page {
    width: 100%;
    max-width: 1080px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
  }
  .logo {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.45rem;
    font-weight: 800;
    color: var(--negro);
    letter-spacing: -0.03em;
  }
  .logo span { color: var(--violeta); }
  .btn-inicio {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--violeta);
    text-decoration: none;
    padding: 10px 15px;
    border: 1.5px solid var(--violeta);
    border-radius: 10px;
    background: var(--violeta-suave);
  }
  .hero {
    background: var(--blanco);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 20px;
    padding: 46px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.12);
    margin-bottom: 18px;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    background: var(--violeta-suave);
    color: var(--violeta);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  h1, h2, h3, .btn {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  h1 {
    font-size: clamp(2.1rem, 5vw, 4rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    text-align: center;
  }
  .hero p {
    max-width: 720px;
    color: var(--gris);
    font-size: 1.05rem;
    line-height: 1.75;
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .card {
    background: var(--blanco);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 16px;
    padding: 28px;
    box-shadow: 0 10px 32px rgba(0,0,0,0.07);
  }
  .card h2 {
    font-size: 1.22rem;
    margin-bottom: 16px;
    text-align: center;
  }
  .card p {
    color: var(--gris);
    line-height: 1.7;
    margin-bottom: 14px;
  }
  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: var(--negro);
    line-height: 1.55;
  }
  li::before {
    content: "\2713";
    flex: 0 0 22px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--violeta-suave);
    color: var(--violeta);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
    margin-top: 1px;
  }
  .comparativa {
    background: var(--blanco);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 20px;
    padding: 30px;
    margin-top: 18px;
    box-shadow: 0 10px 32px rgba(0,0,0,0.07);
  }
  .comparativa h2 {
    text-align: center;
    margin-bottom: 8px;
  }
  .comparativa-sub {
    color: var(--gris);
    text-align: center;
    line-height: 1.7;
    max-width: 680px;
    margin: 0 auto 24px;
  }
  .compare-scene {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: end;
    gap: 18px;
    min-height: 170px;
    padding: 26px;
    border-radius: 16px;
    background: linear-gradient(180deg, #dff8f3 0%, #eef8f0 60%, #d9d4c8 61%, #c4bbaa 100%);
    overflow: hidden;
  }
  .car-visual {
    width: min(100%, 230px);
    height: 86px;
    justify-self: center;
    position: relative;
  }
  .car-body {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 18px;
    height: 42px;
    border-radius: 30px 42px 14px 14px;
    background: linear-gradient(135deg, #173e9f, #224ee6);
    box-shadow: inset 0 -8px 0 rgba(0,0,0,0.18);
  }
  .car-body::before {
    content: "";
    position: absolute;
    left: 48px;
    top: -28px;
    width: 92px;
    height: 38px;
    border-radius: 52px 48px 4px 4px;
    background: #163f9d;
  }
  .car-body::after {
    content: "";
    position: absolute;
    left: 58px;
    top: -20px;
    width: 70px;
    height: 22px;
    border-radius: 30px 28px 2px 2px;
    background: #aee0ef;
  }
  .wheel {
    position: absolute;
    bottom: 8px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #161616;
    border: 5px solid #444;
  }
  .wheel.left { left: 42px; }
  .wheel.right { right: 44px; }
  .vs {
    align-self: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 800;
    color: var(--blanco);
    text-shadow: 0 4px 10px rgba(0,0,0,0.45);
  }
  .building-visual {
    justify-self: center;
    display: flex;
    align-items: end;
    gap: 8px;
  }
  .tower {
    width: 74px;
    height: 132px;
    background: #4b5563;
    border-radius: 4px 4px 0 0;
    padding: 14px 10px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    box-shadow: inset -8px 0 0 rgba(0,0,0,0.15);
  }
  .tower.small {
    height: 98px;
    background: #d8c876;
  }
  .window {
    background: #87c7ee;
    border: 2px solid rgba(0,0,0,0.18);
    border-radius: 2px;
  }
  .compare-table {
    display: grid;
    grid-template-columns: 1fr 0.72fr 1fr;
    gap: 10px 14px;
    align-items: center;
    margin-top: 12px;
  }
  .metric-label {
    text-align: center;
    font-weight: 700;
    color: var(--negro);
    line-height: 1.3;
  }
  .metric-cell {
    min-height: 48px;
    border-radius: 2px;
    background: #ece6ff;
    display: flex;
    align-items: center;
  }
  .metric-cell.left { justify-content: flex-end; }
  .metric-cell.right { justify-content: flex-start; }
  .pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 98px;
    height: 48px;
    padding: 0 20px;
    border-radius: 999px 0 0 999px;
    background: linear-gradient(135deg, #7456ff, #9a77ff);
    color: var(--blanco);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 1.05rem;
    white-space: nowrap;
  }
  .metric-cell.right .pill {
    border-radius: 0 999px 999px 0;
  }
  .pill.short { min-width: 76px; }
  .return-row {
    display: grid;
    grid-template-columns: 1fr 0.72fr 1fr;
    align-items: center;
    gap: 14px;
    margin-top: 18px;
  }
  .return-value {
    text-align: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #7657ff;
    line-height: 1;
  }
  .return-label {
    text-align: center;
    font-weight: 800;
    line-height: 1.25;
  }
  .cta {
    background: var(--blanco);
    border-radius: 20px;
    padding: 34px;
    margin-top: 18px;
    text-align: center;
    border: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 10px 32px rgba(0,0,0,0.07);
  }
  .cta h2 { margin-bottom: 8px; }
  .cta p {
    color: var(--gris);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto;
  }
  .actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-width: 230px;
    padding: 15px 22px;
    border-radius: 12px;
    color: var(--blanco);
    text-decoration: none;
    font-weight: 800;
    border: none;
    transition: transform .2s, filter .2s;
  }
  .btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
  }
  .btn-cotizar {
    background: linear-gradient(135deg, var(--violeta) 0%, #8040b0 100%);
    box-shadow: 0 8px 28px rgba(84,36,116,0.35);
    width: 260px;
  }
  .btn-whatsapp {
    background: var(--verde);
    box-shadow: 0 8px 28px rgba(37,211,102,0.32);
    width: 260px;
  }
  @media (max-width: 760px) {
    body { padding-top: 20px; }
    .topbar { align-items: flex-start; }
    .hero { padding: 30px 22px; }
    .grid { grid-template-columns: 1fr; }
    .card, .cta, .comparativa { padding: 24px 20px; }
    .compare-scene {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 22px 14px;
    }
    .vs { line-height: 1; }
    .compare-table,
    .return-row {
      grid-template-columns: 1fr;
    }
    .metric-label { order: -1; margin-top: 20px; }
    .metric-cell.left,
    .metric-cell.right {
      justify-content: center;
    }
    .pill,
    .metric-cell.right .pill {
      border-radius: 999px;
    }
    .actions { flex-direction: column; }
    .btn { width: 100%; min-width: 0; }
  }
</style>
</head>
<body>
<main class="page">
  <div class="topbar">
    <div class="logo">Red<span>Car</span></div>
    <a href="index.html" class="btn-inicio">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/><path d="M9 21V12h6v9"/></svg>
      Inicio
    </a>
  </div>

  <section class="hero">
    <span class="tag">Due&ntilde;os</span>
